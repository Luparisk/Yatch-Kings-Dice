def rolar_dados(n):
    import random
    lista = []
    i = 0
    while n> i:
        x = random.randint(1,6)
        i += 1
        lista.append(x)
    return lista
def guardar_dado(rol, guard, ind):
    x = rol[ind]
    guard.append(x)
    del rol[ind]
    saida = [rol, guard]
    return saida
def remover_dado(rol, guard, ind):
    rol.append(guard[ind])
    del guard[ind]
    resp = [rol, guard]
    return resp
